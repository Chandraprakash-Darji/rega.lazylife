{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LazyLife DB Schema",
  "description": "Schema for the LazyLife application's db.json file",
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the task"
          },
          "title": {
            "type": "string",
            "description": "Title of the task"
          },
          "done": {
            "type": "boolean",
            "description": "Completion status of the task"
          }
        },
        "required": ["id", "title", "done"]
      }
    },
    "habits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the habit"
          },
          "name": {
            "type": "string",
            "description": "Name of the habit"
          },
          "history": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "date",
              "description": "Date when the habit was performed (YYYY-MM-DD)"
            },
            "description": "List of dates when the habit was performed"
          },
          "active": {
            "type": "boolean",
            "description": "Active status of the habit"
          }
        },
        "required": ["id", "name", "history", "active"]
      }
    },
    "moods": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the mood entry"
          },
          "value": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Mood value (1-5, 1 being worst, 5 being best)"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the mood entry"
          }
        },
        "required": ["id", "value", "timestamp"]
      }
    }
  },
  "required": ["tasks", "habits", "moods"]
}